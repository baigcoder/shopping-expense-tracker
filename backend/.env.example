# ===========================================
# RAILWAY DEPLOYMENT ENVIRONMENT VARIABLES
# ===========================================
# Copy these to Railway Variables dashboard

# Server
PORT=5000
NODE_ENV=production

# Firebase
FIREBASE_PROJECT_ID=tracker-3960c
FIREBASE_STORAGE_BUCKET=tracker-3960c.firebasestorage.app
FIREBASE_DATA_CONNECT_SERVICE=tracker-3960c-service
# Required for Firebase Admin Firestore/Auth user management outside Google-hosted runtimes.
# Paste the full service account JSON on one line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Database (Supabase Postgres - get from Supabase Dashboard > Settings > Database)
# Use the exact pooled connection string from Supabase/Railway.
# A wrong pooler tenant/user causes: FATAL: Tenant or user not found.
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Set false for deployments that only use Firebase/Supabase UID routes such as AI/voice.
AUTH_DB_SYNC_ENABLED=true

# JWT
JWT_SECRET=your_secure_random_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# AI Service (OpenRouter - get from openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1_xxxxxxxxxxxxxxxxxxxx
OPENROUTER_APP_NAME=Cashly
OPENROUTER_CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FAST_CHAT_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_ANALYSIS_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_FORECAST_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_RISK_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_VOICE_MODEL=nvidia/nemotron-nano-9b-v2:free
OPENROUTER_DOCUMENT_MODEL=inclusionai/ling-2.6-1t:free

# Redis (Railway Redis or Upstash)
# If using Railway Redis, set: ${{Redis.REDIS_URL}}
REDIS_URL=redis://default:password@host:port

# ElevenLabs (for voice AI - optional)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Email (for OTP reset - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@cashly.app
